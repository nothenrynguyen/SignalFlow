# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=signalflow
POSTGRES_PASSWORD=signalflow
POSTGRES_DB=signalflow

# Used by the FastAPI backend (postgresql+asyncpg driver)
# In Docker: host is the service name "postgres"
# Local dev: host is localhost
DATABASE_URL=postgresql+asyncpg://signalflow:signalflow@postgres:5432/signalflow

# ─── Redis ────────────────────────────────────────────────────────────────────
# In Docker: host is the service name "redis"
# Local dev: host is localhost
REDIS_URL=redis://redis:6379

# ─── Frontend ─────────────────────────────────────────────────────────────────
# For local dev these point to localhost. In Docker they point to the backend service.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/metrics
